<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_product_cost" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.product.cost</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//app[@name='general_settings']" position="inside">
                <block title="Product Cost Visibility" name="product_cost_visibility_block">
                    <setting id="product_cost_visibility_setting"
                             string="Users Allowed to See Product Cost"
                             help="Select the users who can see the Cost field on the product screen. Users not listed here will not see the product cost.">
                        <field name="product_cost_user_ids" widget="many2many_tags"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
