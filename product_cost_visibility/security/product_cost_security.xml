<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Security group that grants the right to see the product Cost field.
        Membership is managed from Settings (see res.config.settings), but the
        group can also be assigned manually from the user form.
        The administrator is added by default so that cost stays visible
        out of the box right after installation.
    -->
    <record id="group_product_cost_visibility" model="res.groups">
        <field name="name">Show Product Cost</field>
        <field name="category_id" ref="base.module_category_hidden"/>
        <field name="comment">Users in this group can see the Cost field on the product screen.</field>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

</odoo>
